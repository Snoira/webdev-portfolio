---
import "@styles/plein.css";
import world from "@assets/images/hero/world.svg";
import flower_stem from "@assets/images/hero/flower_stem.svg";
import flower from "@assets/images/hero/flower.svg";
import { Image } from "astro:assets";
---

<section class="hero" id="hero">
  <div class="image-wrapper">
    <div class="image-container">
      <Image
        src={flower_stem}
        alt="Doodle of a flower stem"
        class="hero-image flower-stem"
      />
      <Image src={world} alt="Doodle of the world" class="hero-image world" />
      <Image src={flower} alt="Doodle of a flower" class="hero-image flower" />
    </div>
  </div>
  <div class="text-container">
    <h1 class="text">Hello, <br />I’m Nora!</h1>
    <p>
      A fullstack developer with a background in environmental science and
      social geography.
    </p>
  </div>
</section>

<style>
  h1,
  p {
    text-align: left;
    text-shadow: 2px 2px 4px rgba(255, 255, 255, 0.2);
    z-index: 1;
  }

  h1 {
    font-weight: 900;
    line-height: 1.2;
    font-size: clamp(3rem, 9vw, 4rem);
  }

  p {
    font-family: "Plein", Arial, Helvetica, sans-serif;
    font-weight: 600;
    line-height: 1.4;
    max-width: 600px;
    margin-top: 0.5rem;
    font-size: clamp(1.25rem, 3.7vw, 1.5rem);
  }

  .hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 4rem 0rem;
    margin: 0 auto;
    max-width: 600px;
  }

  .image-container {
    position: relative;
    aspect-ratio: 1/1;
    height: 100%;
    max-width: 500px;
    align-self: flex-end;
  }

  .world {
    max-width: 100%;
    height: auto;
  }

  .flower-stem {
    position: absolute;
    max-width: 70%;
    height: auto;
    bottom: -21.5%;
    left: 21%;
  }

  .flower {
    position: absolute;
    max-width: 30%;
    bottom: 0;
    right: 2%;
    height: auto;
  }
  .text-container {
    margin-top: -1.5rem;
    padding: 0rem 1rem;
    align-self: flex-start;
    position: relative;
  }

  @media (min-width: 768px) {
    .hero {
      position: relative;
      padding: 0 2rem;
      flex-direction: row-reverse;
      justify-content: space-between;
      max-width: none;
      height: 95dvh;
      max-width: 1280px;
    }
    .text-container {
      position: absolute;
      bottom: 10%;
      left: 2rem;
    }
    .image-wrapper {
      position: absolute;
      right: 0;
      height: 100%;
      width: 100%;
      display: flex;
      justify-content: flex-end;
      align-items: center;
      padding-right: 2rem;
      padding-bottom: 2rem;
      max-height: 750px;
    }
    .image-container {
      max-width: 100vw;
      aspect-ratio: none;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 65%;
      height: 100%;
      max-width: 800px;
    }
    .flower,
    .flower-stem,
    .world {
      position: absolute;
      width: 100%;
    }
    .world {
      width: 100%;
    }
    .flower-stem {
      width: 85%;
      align-self: flex-start;
      top: 5%;
      left: -50%;
      z-index: 1;
    }
    .flower {
      width: 30%;
      bottom: 0;
      right: 0;
    }
  }
</style>
