<style>
  h1,
  p {
    text-align: left;
    text-shadow: 2px 2px 4px rgba(255, 255, 255, 0.2);
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
    z-index: 1;
    color: var(--white);
    text-align: center;
  }

  h1 {
    font-weight: 900;
    line-height: 1.2;
    font-size: clamp(3rem, 9vw, 5rem);
    /* font-size: 4rem; */
  }

  .highlight {
    color: #fa888f;
  }

  p {
    font-family: "Plein", Arial, Helvetica, sans-serif;
    font-weight: 600;
    line-height: 1.4;
    max-width: 600px;
    margin-top: 0.5rem;
    font-size: clamp(1.25rem, 3.7vw, 1.5rem);
  }
  .hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 4rem 0.5rem;
    margin: 0 auto 4rem auto;
    min-height: 60dvh;
  }
  /* 
  .hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 4rem 0rem;
    margin: 0 auto 4rem auto;
    max-width: 600px;
    
  } */

  /* .text-container {
    margin-top: -1.5rem;
    padding: 0rem 1rem;
    align-self: flex-start;
    position: relative;
  } */

  @media (min-width: 768px) {
    h1 {
      font-size: 6rem;
    }
    p{
      margin-top: 1rem;
    }
  }
</style>
